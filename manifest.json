{
    "manifest_version": 3,
    "name": "My Extension",
    "version": "1.0",
    "description": "Unlocks useful features for Teja Karlapudi",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Domain Blocker"
    },
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "youtube-player-buttons.js",
                "youtube-playlist-buttons.js",
                "yt-music-playlist-filtering.js",
                "youtube-topbar-buttons.js",
                "youtube-homepage-watch-later.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "domain-blocker.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://x.com/*",
                "*://www.x.com/*"
            ],
            "js": [
                "text-selection-popup.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://claude.ai/*",
                "*://claude.com/*"
            ],
            "js": [
                "claude-input.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://chatgpt.com/*",
                "*://chat.openai.com/*"
            ],
            "js": [
                "chatgpt-input.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "*://www.youtube.com/*",
        "*://claude.ai/*",
        "*://claude.com/*",
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "<all_urls>"
    ],
    "permissions": [
        "storage",
        "tabs",
        "contextMenus",
        "bookmarks"
    ],
    "background": {
        "service_worker": "custom-context-menu-actions.js"
    },
    "commands": {
        "close-other-tabs-shortcut": {
            "suggested_key": {
                "default": "Ctrl+Shift+Y",
                "mac": "Command+Shift+Y"
            },
            "description": "Close all tabs except the current tab and pinned tabs"
        }
    },
    "icons": {
        "48": "icon.png"
    }
}