{
    "manifest_version": 3,
    "name": "My Extension",
    "version": "1.0",
    "description": "Unlocks useful features for Teja Karlapudi",
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "content.js",
                "playlist-icons.js",
                "yt-music-playlist-filtering.js",
                "yt-autoplay-disabler.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "*://www.youtube.com/*"
    ],
    "icons": {
        "48": "icon.png"
    }
}