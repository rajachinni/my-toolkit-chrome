{
    "manifest_version": 3,
    "name": "My Extension",
    "version": "1.0",
    "description": "Unlocks useful features for Teja Karlapudi",
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "content.js",
                "playlist-icons.js",
                "yt-music-playlist-filtering.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://you.com/",
                "https://you.com/*"
            ],
            "js": [
                "you-web-search-disabler.js",
                "you-auto-select-model.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "*://www.youtube.com/*",
        "https://you.com/"
    ],
    "icons": {
        "48": "icon.png"
    }
}